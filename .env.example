# --- required ---
CARTESIA_API_KEY=sk_car_...
# the deployed Line agent that answers calls (from your Cartesia dashboard)
CARTESIA_AGENT_ID=agent_...
# the shared secret from your StandIn identity (pairing issues it); must match exactly
WORKER_SHARED_SECRET=change-me

# --- per-call agent overrides (all optional - your Line agent's own config is the default) ---
# override the agent's TTS voice for calls through this bridge
#CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091
# deterministic opening line / spoken AI disclosure (start agent.introduction)
#CARTESIA_INTRODUCTION=Hello! You've reached Komaa. How can I help?
# system-prompt override (start agent.system_prompt). When set, per-call caller
# context (name, tenant, direction) is appended; unset = the deployed agent's own
# prompt is used untouched (caller context still rides the start metadata).
#CARTESIA_SYSTEM_PROMPT=You are Komaa's friendly receptionist. Keep replies short; you are speaking aloud on a phone call.

# --- optional ---
PORT=8080
BIND=0.0.0.0

# TLS: with BOTH set the bridge serves wss:// itself. Without them it is plain WS
# and MUST be fronted by a TLS terminator (tunnel / ingress / LB) - caller audio
# would otherwise cross the wire in plaintext.
#TLS_CERT_PATH=/path/to/fullchain.pem
#TLS_KEY_PATH=/path/to/privkey.pem

# Per-IP connection cap. Default = MAX_CONNECTIONS (effectively no per-IP throttle):
# StandIn dials from a small set of IPs, so a low per-IP cap would silently limit
# total concurrent calls. Set TRUST_PROXY_XFF=true to key it on X-Forwarded-For
# behind a proxy you control.
#MAX_CONNECTIONS_PER_IP=0
#TRUST_PROXY_XFF=false

# Cartesia host (restricted to *.cartesia.ai so the API key can't be sent elsewhere;
# CARTESIA_HOST_ALLOW_ANY=true only for a deliberate trusted proxy/test host).
#CARTESIA_API_HOST=api.cartesia.ai
#CARTESIA_HOST_ALLOW_ANY=true
# Cartesia-Version header sent on every request
#CARTESIA_VERSION=2025-04-16

# Deterministic governor goodbye via standalone Sonic TTS (exact text, real duration).
# Needs a model AND a voice (CARTESIA_TTS_VOICE_ID, or CARTESIA_VOICE_ID as fallback).
# Without them the goodbye is a `custom` {type: "goodbye_request"} event your Line
# agent code may handle - silent otherwise.
#CARTESIA_TTS_MODEL=sonic-2
#CARTESIA_TTS_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091
#CARTESIA_TTS_LANGUAGE=en

# bridge-side call governor: hard cap in minutes (fractional ok); 0 = disabled
MAX_CALL_MINUTES=0
#GOODBYE_TEXT=I'm sorry, we've reached the time limit for this call. Thank you for calling, goodbye!
# grace before session.end when the goodbye duration is unknown (goodbye_request fallback)
GOODBYE_GRACE_MS=8000

# HMAC replay window in ms (worker documents +-60s)
HMAC_FRESHNESS_MS=60000
# DoS guards (0 = built-in defaults: 64 / =total / 10000 / 90000)
MAX_CONNECTIONS=0
MAX_CONNECTIONS_PER_IP=0
PRE_START_TIMEOUT_MS=0
# dead-peer window: end the call after this many ms without any worker message (worker pings every 30s)
WORKER_IDLE_TIMEOUT_MS=0
LOG_LEVEL=info
